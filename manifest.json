{
	"manifest_version": 2,

	"name": "Le Monastere",
	"description": "Une petite extension pour se tenir informer des dernières sorties des meilleurs mangas",
	"version": "0.1",
	"background": {
		"scripts": ["background.js"]
	},

	"permissions": ["tabs", "contextMenus", "https://www.asurascans.com/*"],
	"browser_action": {
		"default_icon": "manga.png",
		"default_title": "Lancer la recherche"
	},
    "sidebar_action": {
		"default_icon": "manga.png",
		"default_title" : "Le Monastere",
		"default_panel": "WebPage/index.html"
	}
}